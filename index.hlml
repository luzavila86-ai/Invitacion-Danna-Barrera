<!DOCTYPE html><html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mis XV - Dana Camila</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      height: 100vh;
      font-family: 'Segoe UI', sans-serif;
      color: white;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      background-image: url('noche-estrellada.jpg');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }.overlay {
  background: rgba(0,0,0,0.5);
  padding: 20px;
  border-radius: 20px;
}

h1 {
  font-size: 3em;
  margin: 10px 0;
  overflow: hidden;
  border-right: .15em solid #fff;
  white-space: nowrap;
  animation: typing 4s steps(30, end), blink .75s step-end infinite;
}

h2 {
  font-size: 2em;
  margin-bottom: 20px;
}

p {
  font-size: 1.2em;
  margin: 10px 0;
}

.ubicacion {
  margin-top: 20px;
  font-size: 1.1em;
}

.btn {
  margin-top: 20px;
  padding: 12px 20px;
  background: gold;
  color: black;
  text-decoration: none;
  border-radius: 10px;
  font-weight: bold;
}

@keyframes typing {
  from { width: 0 }
  to { width: 100% }
}

@keyframes blink {
  from, to { border-color: transparent }
  50% { border-color: white }
}

  </style>
</head>
<body>  <div class="overlay">
    <h2>Mis quince años</h2>
    <h1>Dana Camila</h1><p>Te invito a celebrar este momento tan especial</p>

<div class="ubicacion">
  📍 Centro Cultural Casa Clare<br>
  Calle 63 Sur #80 - Boza
</div>

<a href="#" class="btn">Confirmar asistencia</a>

  </div></body>
</html> 
